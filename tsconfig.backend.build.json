{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist/back",
    "rootDir": "src/backend",
    "types": ["node"],
    "noEmit": false,
    "declaration": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["src/backend/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
